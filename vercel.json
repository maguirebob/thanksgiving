{
  "version": 2,
  "builds": [
    {
      "src": "api/index-with-raw-sql.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index-with-raw-sql.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Post - Thanksgiving Blog</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/css/blog.css" rel="stylesheet">
    <!-- Rich Text Editor -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
</head>
<body>
    <div class="container-fluid">
        <!-- Header -->
        <header class="blog-header">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/blog">Blog</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Create New Post</li>
                            </ol>
                        </nav>
                    </div>
                    <div class="col-md-4 text-end">
                        <a href="/blog" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>
                            Back to Blog
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="blog-main">
            <div class="container">
                <div class="row">
                    <div class="col-lg-8">
                        <form id="blogPostForm" class="blog-post-form">
                            <!-- Post Title -->
                            <div class="form-group mb-4">
                                <label for="postTitle" class="form-label">Post Title *</label>
                                <input type="text" class="form-control" id="postTitle" name="title" required>
                                <div class="form-text">A compelling title that describes your post</div>
                            </div>

                            <!-- Post Slug -->
                            <div class="form-group mb-4">
                                <label for="postSlug" class="form-label">URL Slug</label>
                                <input type="text" class="form-control" id="postSlug" name="slug">
                                <div class="form-text">Leave empty to auto-generate from title</div>
                            </div>

                            <!-- Post Excerpt -->
                            <div class="form-group mb-4">
                                <label for="postExcerpt" class="form-label">Excerpt</label>
                                <textarea class="form-control" id="postExcerpt" name="excerpt" rows="3"></textarea>
                                <div class="form-text">A brief summary of your post (optional)</div>
                            </div>

                            <!-- Post Content -->
                            <div class="form-group mb-4">
                                <label for="postContent" class="form-label">Content *</label>
                                <div id="postContentEditor"></div>
                                <input type="hidden" id="postContent" name="content">
                                <div class="form-text">Write your blog post content here</div>
                            </div>

                            <!-- Featured Image -->
                            <div class="form-group mb-4">
                                <label for="featuredImage" class="form-label">Featured Image URL</label>
                                <input type="url" class="form-control" id="featuredImage" name="featured_image_url">
                                <div class="form-text">URL to the featured image for your post</div>
                            </div>

                            <!-- Post Settings -->
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="postStatus" class="form-label">Status</label>
                                        <select class="form-select" id="postStatus" name="status">
                                            <option value="draft">Draft</option>
                                            <option value="published">Published</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="postCategory" class="form-label">Category</label>
                                        <select class="form-select" id="postCategory" name="category_id">
                                            <option value="">Select a category</option>
                                            <!-- Categories will be loaded here -->
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Event Association -->
                            <div class="form-group mb-4">
                                <label for="postEvent" class="form-label">Associated Thanksgiving Event</label>
                                <select class="form-select" id="postEvent" name="event_id">
                                    <option value="">Select an event (optional)</option>
                                    <!-- Events will be loaded here -->
                                </select>
                                <div class="form-text">Link this post to a specific Thanksgiving event</div>
                            </div>

                            <!-- Tags -->
                            <div class="form-group mb-4">
                                <label for="postTags" class="form-label">Tags</label>
                                <input type="text" class="form-control" id="postTags" name="tags">
                                <div class="form-text">Separate tags with commas (e.g., turkey, recipes, family)</div>
                            </div>

                            <!-- Featured Post -->
                            <div class="form-check mb-4">
                                <input class="form-check-input" type="checkbox" id="isFeatured" name="is_featured">
                                <label class="form-check-label" for="isFeatured">
                                    Mark as featured post
                                </label>
                            </div>

                            <!-- Form Actions -->
                            <div class="form-actions">
                                <button type="button" class="btn btn-outline-secondary" id="saveDraftBtn">
                                    <i class="fas fa-save me-2"></i>
                                    Save as Draft
                                </button>
                                <button type="submit" class="btn btn-primary" id="publishBtn">
                                    <i class="fas fa-paper-plane me-2"></i>
                                    Publish Post
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Sidebar -->
                    <div class="col-lg-4">
                        <!-- Post Preview -->
                        <div class="blog-sidebar-widget">
                            <h5 class="widget-title">
                                <i class="fas fa-eye me-2"></i>
                                Preview
                            </h5>
                            <div id="postPreview" class="post-preview">
                                <p class="text-muted">Start typing to see a preview of your post...</p>
                            </div>
                        </div>

                        <!-- Writing Tips -->
                        <div class="blog-sidebar-widget">
                            <h5 class="widget-title">
                                <i class="fas fa-lightbulb me-2"></i>
                                Writing Tips
                            </h5>
                            <ul class="tips-list">
                                <li>Use a compelling title that draws readers in</li>
                                <li>Write a clear, engaging excerpt</li>
                                <li>Use headings to organize your content</li>
                                <li>Add relevant tags to help readers find your post</li>
                                <li>Include a featured image to make your post stand out</li>
                            </ul>
                        </div>

                        <!-- Categories -->
                        <div class="blog-sidebar-widget">
                            <h5 class="widget-title">
                                <i class="fas fa-folder me-2"></i>
                                Categories
                            </h5>
                            <div id="categoriesList">
                                <!-- Categories will be loaded here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="/js/blogManager.js"></script>
    <script>
        // Initialize blog create functionality
        document.addEventListener('DOMContentLoaded', function() {
            const blogManager = new BlogManager();
            blogManager.initCreate();
        });
    </script>
</body>
</html>

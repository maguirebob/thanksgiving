<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog - Thanksgiving Memories</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/css/blog.css" rel="stylesheet">
</head>
<body>
    <div class="container-fluid">
        <!-- Header -->
        <header class="blog-header">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h1 class="blog-title">
                            <i class="fas fa-blog me-2"></i>
                            Thanksgiving Blog
                        </h1>
                        <p class="blog-subtitle">Stories, recipes, and memories from our family gatherings</p>
                    </div>
                    <div class="col-md-4 text-end">
                        <a href="/blog/create" class="btn btn-primary btn-lg">
                            <i class="fas fa-plus me-2"></i>
                            Write New Post
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- Navigation -->
        <nav class="blog-nav">
            <div class="container">
                <ul class="nav nav-pills">
                    <li class="nav-item">
                        <a class="nav-link active" href="#" data-filter="all">All Posts</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-filter="featured">Featured</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-filter="recent">Recent</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-filter="popular">Popular</a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="blog-main">
            <div class="container">
                <div class="row">
                    <!-- Blog Posts -->
                    <div class="col-lg-8">
                        <!-- Search Bar -->
                        <div class="blog-search mb-4">
                            <div class="input-group">
                                <input type="text" class="form-control" id="blogSearch" placeholder="Search blog posts...">
                                <button class="btn btn-outline-secondary" type="button" id="searchBtn">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Loading Indicator -->
                        <div id="loadingIndicator" class="text-center py-5" style="display: none;">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Loading blog posts...</p>
                        </div>

                        <!-- Blog Posts Container -->
                        <div id="blogPostsContainer">
                            <!-- Blog posts will be loaded here -->
                        </div>

                        <!-- Pagination -->
                        <nav aria-label="Blog pagination" class="mt-5">
                            <ul class="pagination justify-content-center" id="blogPagination">
                                <!-- Pagination will be generated here -->
                            </ul>
                        </nav>
                    </div>

                    <!-- Sidebar -->
                    <div class="col-lg-4">
                        <!-- Categories -->
                        <div class="blog-sidebar-widget">
                            <h5 class="widget-title">
                                <i class="fas fa-folder me-2"></i>
                                Categories
                            </h5>
                            <div id="categoriesList">
                                <!-- Categories will be loaded here -->
                            </div>
                        </div>

                        <!-- Popular Tags -->
                        <div class="blog-sidebar-widget">
                            <h5 class="widget-title">
                                <i class="fas fa-tags me-2"></i>
                                Popular Tags
                            </h5>
                            <div id="tagsList">
                                <!-- Tags will be loaded here -->
                            </div>
                        </div>

                        <!-- Recent Posts -->
                        <div class="blog-sidebar-widget">
                            <h5 class="widget-title">
                                <i class="fas fa-clock me-2"></i>
                                Recent Posts
                            </h5>
                            <div id="recentPostsList">
                                <!-- Recent posts will be loaded here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/blogManager.js"></script>
    <script>
        // Initialize blog functionality
        document.addEventListener('DOMContentLoaded', function() {
            const blogManager = new BlogManager();
            blogManager.init();
        });
    </script>
</body>
</html>
